{
  "project": {
    "name": "TipSplit",
    "description": "A single-page tip calculator for splitting a restaurant bill. The user enters the bill amount, picks a tip percentage from quick presets (10%, 15%, 20%) or a custom value, specifies the number of people, and instantly sees the tip amount, total bill, and per-person share.",
    "type": "web-application",
    "complexity": "low-medium",
    "version": "1.0.0",
    "techStack": {
      "frontend": "React",
      "backend": "FastAPI",
      "database": "PostgreSQL",
      "styling": "CSS Modules / TailwindCSS",
      "stateManagement": "React Context / useState",
      "apiCommunication": "REST (Axios/Fetch)"
    }
  },
